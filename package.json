{
  "description": "Shopify TanStack Router - to simplify building Shopify apps with TanStack Router",
  "name": "@yanuaraditia/shopify-app-tanstack",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yanuaraditia/shopify-app-tanstack.git"
  },
  "bugs": {
    "url": "https://github.com/yanuaraditia/shopify-app-tanstack/issues"
  },
  "homepage": "https://github.com/yanuaraditia/shopify-app-tanstack",
  "author": "Community Maintainers",
  "license": "MIT",
  "main": "./dist/cjs/server/index.js",
  "module": "./dist/esm/server/index.mjs",
  "types": "./dist/ts/server/index.d.ts",
  "exports": {
    "./adapters/*": {
      "types": "./dist/ts/server/adapters/*/index.d.ts",
      "require": "./dist/cjs/server/adapters/*/index.js",
      "import": "./dist/esm/server/adapters/*/index.mjs",
      "default": "./dist/cjs/server/adapters/*/index.js"
    },
    "./server/adapters/*": {
      "types": "./dist/ts/server/adapters/*/index.d.ts",
      "require": "./dist/cjs/server/adapters/*/index.js",
      "import": "./dist/esm/server/adapters/*/index.mjs",
      "default": "./dist/cjs/server/adapters/*/index.js"
    },
    "./server": {
      "types": "./dist/ts/server/index.d.ts",
      "require": "./dist/cjs/server/index.js",
      "import": "./dist/esm/server/index.mjs",
      "default": "./dist/cjs/server/index.js"
    },
    "./react": {
      "types": "./dist/ts/react/index.d.ts",
      "require": "./dist/cjs/react/index.js",
      "import": "./dist/esm/react/index.mjs",
      "default": "./dist/cjs/react/index.js"
    },
    "./test-helpers": {
      "types": "./dist/ts/server/test-helpers/index.d.ts",
      "require": "./dist/cjs/server/test-helpers/index.js",
      "import": "./dist/esm/server/test-helpers/index.mjs",
      "default": "./dist/cjs/server/test-helpers/index.js"
    }
  },
  "scripts": {
    "build-docs": "sh docs/build-docs.sh",
    "validate-docs": "sh ./docs/build-docs.sh isTest && bun run compare-docs",
    "lint": "eslint .",
    "build": "bun run vite:esm && bun run vite:cjs && bun run tsc -p ./tsconfig.build.json",
    "tsc": "tsc",
    "test": "vitest run",
    "test:ci": "bun run test",
    "vite:esm": "vite build --mode esm",
    "vite:cjs": "vite build --mode cjs",
    "clean": "rimraf .vite dist",
    "changelog": "changelogen --output CHANGELOG.md",
    "changelog:bump": "changelogen --bump --output CHANGELOG.md",
    "release": "bun run build && changelogen --release --output CHANGELOG.md"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "shopify",
    "javascript",
    "typescript",
    "tanstack-router",
    "app",
    "graphql",
    "rest",
    "webhook",
    "Admin API",
    "Storefront API"
  ],
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "changelogen": "^0.6.2",
    "@shopify/eslint-plugin": "^50.0.0",
    "@shopify/generate-docs": "^1.2.0",
    "@shopify/prettier-config": "^1.1.4",
    "@shopify/react-testing": "^6.0.0",
    "@shopify/shopify-app-session-storage-memory": "^6.0.0",
    "@shopify/typescript-configs": "^5.1.2",
    "@tanstack/react-router": "^1.169.2",
    "@types/react": "^19.2.14",
    "eslint": "^9.39.0",
    "eslint-import-resolver-node": "^0.3.10",
    "jiti": "^2.7.0",
    "jsdom": "^26.1.0",
    "vite": "^8.0.10",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@shopify/admin-api-client": "^1.1.2",
    "@shopify/shopify-api": "^13.0.0",
    "@shopify/shopify-app-session-storage": "^5.0.0",
    "@shopify/storefront-api-client": "^1.0.10",
    "compare-versions": "^6.1.1",
    "isbot": "^5.1.40"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@tanstack/react-router": "^1.169.2"
  },
  "files": [
    "dist/*",
    "src",
    "!src/**/__tests__",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!build/**/__tests__",
    "!tsconfig.tsbuildinfo",
    "!node_modules"
  ]
}
